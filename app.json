{
  "expo": {
    "name": "gAIn",
    "slug": "gain",
    "version": "1.0.0",
    "description": "Smarter Trainingsbegleiter: Workouts planen, Sätze tracken und KI-gestützte Fortschrittsanalyse – funktioniert auch offline.",
    "primaryColor": "#7ee787",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gain",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d12"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gain.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0d12"
      },
      "package": "com.gain.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "gAIn nutzt das Mikrofon für die Spracheingabe im KI-Coach."
        }
      ]
    ]
  }
}
